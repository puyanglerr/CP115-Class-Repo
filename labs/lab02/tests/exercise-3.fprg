<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="exercise-3"/>
        <attribute name="authors" value="User"/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-06-28 10:26:22 PM"/>
        <attribute name="created" value="VXNlcjtMQVBUT1AtQjhRSUZJT1Y7MjAyNi0wNi0yODsxMDowMzo1NiBQTTsyNzkz"/>
        <attribute name="edited" value="VXNlcjtMQVBUT1AtQjhRSUZJT1Y7MjAyNi0wNi0yODsxMDoyNjoyMiBQTTsxOzI4OTk="/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="watts, hours, chargeperkilowatthour, costnight, costmonth, totalcost, kwattspernight" type="Real" array="False" size=""/>
            <input variable="watts"/>
            <assign variable="watts" expression="watts/1000"/>
            <input variable="hours"/>
            <assign variable="kwattspernight" expression="watts*hours"/>
            <assign variable="costnight" expression="0.218*hours"/>
            <assign variable="costmonth" expression="costnight*30"/>
            <assign variable="totalcost" expression="costmonth"/>
            <output expression="totalcost" newline="True"/>
        </body>
    </function>
</flowgorithm>
