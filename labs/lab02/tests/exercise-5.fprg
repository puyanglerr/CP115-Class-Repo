    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="servicefee, numberphoto, totalcost" type="Real" array="False" size=""/>
            <input variable="numberphoto"/>
            <assign variable="servicefee" expression="2"/>
            <assign variable="totalcost" expression="0.50*numberphoto+servicefee"/>
