<?xml version="1.0"?>
<flowgorithm fileversion="4.2">
    <attributes>
        <attribute name="name" value="exercise-1"/>
        <attribute name="authors" value="User"/>
        <attribute name="about" value=""/>
        <attribute name="saved" value="2026-06-24 01:27:59 PM"/>
        <attribute name="created" value="VXNlcjtMQVBUT1AtQjhRSUZJT1Y7MjAyNi0wNi0yNDswOToxMjozMSBBTTsyNzc1"/>
        <attribute name="edited" value="VXNlcjtMQVBUT1AtQjhRSUZJT1Y7MjAyNi0wNi0yNDswMToyNzo1OSBQTTsyOzI5MDc="/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="ringgit, commission, rate, balance, Baht" type="Real" array="False" size=""/>
            <input variable="ringgit"/>
            <input variable="rate"/>
            <assign variable="commission" expression="ringgit*0.02"/>
            <assign variable="balance" expression="ringgit-commission"/>
            <assign variable="Baht" expression="balance*8.02"/>
            <output expression="Baht" newline="True"/>
        </body>
    </function>
</flowgorithm>
