    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="petrolinlitre, distance, totalcost" type="Real" array="False" size=""/>
            <input variable="distance"/>
            <assign variable="petrolinlitre" expression="(distance/100)*8"/>
            <assign variable="totalcost" expression="petrolinlitre*2.05"/>
            <output expression="totalcost" newline="True"/>
        </body>
    </function>
