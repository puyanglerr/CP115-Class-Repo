    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="basicRate, serviceCharge, numNight, totalPayment" type="Integer" array="False" size=""/>
            <input variable="numNight"/>
            <assign variable="basicRate" expression="250*numNight"/>
            <assign variable="serviceCharge" expression="(15/100)*250"/>
            <assign variable="totalPayment" expression="basicRate+serviceCharge"/>
        </body>
    </function>
